# =============================================================================
# macOS
# =============================================================================
**/.DS_Store

# =============================================================================
# ZSH — generated state & session artifacts
# =============================================================================
**/.zcompdump
**/.zsh_history
zsh/.zsh_sessions/

# =============================================================================
# Shell secrets (never commit)
# =============================================================================
zsh/secrets.zsh
**/secrets.zsh

# =============================================================================
# XDG cache & local data
# =============================================================================
**/cache/
**/local/share/

# =============================================================================
# Tool state & caches (auto-generated, machine-specific)
# =============================================================================
**/.config/gh/
**/.config/btop/
**/.config/claude/
**/.config/.copilot/
**/.config/github-copilot/
**/.config/raycast/
**/.config/colima/
**/.config/lazygit/state.yml
**/.config/pgcli/log
**/.config/pgcli/history
**/.config/cagent/
**/.config/opencode/

# =============================================================================
# Editor/tool runtime & backup directories
# =============================================================================
**/.config/nvim/
**/.config/helix/runtime
**/.config/helix/.claude/
**/.config/helix/.helix/
**/.config/zed/

# =============================================================================
# Claude Code — runtime state & secrets (never commit)
# =============================================================================
# Whitelist under the `claude/` stow package: ignore everything, then re-include
# only the curated files.
claude/.claude/*
!claude/.claude/settings.json
!claude/.claude/statusline-command.sh
!claude/.claude/commands/
claude/.claude/commands/*
!claude/.claude/commands/*.md

# Belt-and-suspenders: refuse obvious secret/state paths anywhere in the repo
**/.claude.json
**/.claude/.credentials.json
**/.claude/history.jsonl
**/.claude/sessions/
**/.claude/projects/
**/.claude/plans/
**/.claude/tasks/
**/.claude/paste-cache/
**/.claude/file-history/
**/.claude/session-env/
**/.claude/shell-snapshots/
**/.claude/telemetry/
**/.claude/backups/
**/.claude/cache/
**/.claude/downloads/
**/.claude/plugins/
**/.claude/policy-limits.json
