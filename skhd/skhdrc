# Open apps
cmd - return : /Applications/Alacritty.app/Contents/MacOS/alacritty

# Create Spaces
# alt - n : yabai -m space --create
# shift + alt - n : yabai -m space --create; yabai -m query --spaces --display | jq '.[-1].index' | xargs yabai -m space --focus
# 
# # Destroy spaces
# alt - d : yabai -m space --destroy
# 
# # Toggle fullscreen
# alt - f : yabai -m window --toggle zoom-parent
# 
# # Focus Spaces
# alt - 1 : yabai -m space --focus 1
# alt - 2 : yabai -m space --focus 2
# alt - 3 : yabai -m space --focus 3
# alt - 4 : yabai -m space --focus 4
# alt - 5 : yabai -m space --focus 5
# alt - 6 : yabai -m space --focus 6
# alt - 7 : yabai -m space --focus 7
# alt - 8 : yabai -m space --focus 8
# alt - 9 : yabai -m space --focus 9
# cmd - j : yabai -m window --focus next || yabai -m window --focus first
# cmd - k : yabai -m window --focus prev || yabai -m window --focus last
# 
# # Move window
# shift + alt - 1 : yabai -m window --space 1; yabai -m space --focus 1
# shift + alt - 2 : yabai -m window --space 2; yabai -m space --focus 2
# shift + alt - 3 : yabai -m window --space 3; yabai -m space --focus 3
# shift + alt - 4 : yabai -m window --space 4; yabai -m space --focus 4
# shift + alt - 5 : yabai -m window --space 5; yabai -m space --focus 5
# shift + alt - 6 : yabai -m window --space 6; yabai -m space --focus 6
# shift + alt - 7 : yabai -m window --space 7; yabai -m space --focus 7
# shift + alt - 8 : yabai -m window --space 8; yabai -m space --focus 8
# shift + alt - 9 : yabai -m window --space 9; yabai -m space --focus 9




